@model Proyecto_PlataformaPeliculas.Models.MovieSearchViewModel

@{
    ViewData["Title"] = "Explorador de Películas";
}

<h2>Explorador de Películas</h2>

<form asp-action="Search" method="get">
    <div>
        <label>Nombre:</label>
        <input type="text" name="query" value="@Model.Query" />
    </div>

    <div>
        <label>Género:</label>
        <select name="genreId">
            <option value="">-- Seleccione género --</option>
            @foreach (var genre in Model.Genres)
            {
                if (Model.GenreId == genre.Id)
                {
                    <option value="@genre.Id" selected>@genre.Name</option>
                }
                else
                {
                    <option value="@genre.Id">@genre.Name</option>
                }
            }
        </select>
    </div>

    <div>
        <label>Idioma:</label>
        <select name="language">
            <option value="">-- Seleccione idioma --</option>
            @foreach (var lang in Model.Languages)
            {
                if (Model.Language == lang)
                {
                    <option value="@lang" selected>@lang</option>
                }
                else
                {
                    <option value="@lang">@lang</option>
                }
            }
        </select>
    </div>

    <div>
        <label>Año:</label>
        <select name="year">
            <option value="">-- Seleccione año --</option>
            @foreach (var y in Model.Years)
            {
                if (Model.Year == y)
                {
                    <option value="@y" selected>@y</option>
                }
                else
                {
                    <option value="@y">@y</option>
                }
            }
        </select>
    </div>

    <button type="submit">Buscar</button>
</form>

<hr />

@if (Model.Results != null && Model.Results.Any())
{
    <h3>Resultados</h3>

    @foreach (var movie in Model.Results)
    {
        <div style="border:1px solid #ccc; padding:12px; margin-bottom:12px;">
            <h4>@movie.Title</h4>

            @if (!string.IsNullOrWhiteSpace(movie.PosterPath))
            {
                <img src="@($"https://image.tmdb.org/t/p/w200{movie.PosterPath}")" alt="@movie.Title" />
            }

            <p><strong>Fecha:</strong> @movie.ReleaseDate</p>
            <p><strong>Idioma:</strong> @movie.OriginalLanguage</p>
            <p>
                <strong>Géneros:</strong>
                @{
                    var genreNames = Model.Genres
                    .Where(g => movie.GenreIds.Contains(g.Id))
                    .Select(g => g.Name)
                    .ToList();
                }

                @if (genreNames.Any())
                {
                    @string.Join(", ", genreNames)
                }
                else
                {
                    <span>No disponible</span>
                }
            </p>
            <p><strong>Calificación:</strong> @movie.VoteAverage</p>
            <p>@movie.Overview</p>

            <a asp-action="Details" asp-route-id="@movie.Id">Ver detalle</a>
        </div>
    }
}
else
{
    <p>No hay resultados para mostrar.</p>
}