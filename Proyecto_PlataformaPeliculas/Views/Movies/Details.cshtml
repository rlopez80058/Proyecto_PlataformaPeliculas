@model Proyecto_PlataformaPeliculas.Models.MovieDetailViewModel

@{
    ViewData["Title"] = "Detalle de Película";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary">← Volver al explorador</a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="row g-0">
            <div class="col-md-4 bg-light text-center">
                @if (!string.IsNullOrWhiteSpace(Model.PosterPath))
                {
                    <img src="@($"https://image.tmdb.org/t/p/w400{Model.PosterPath}")"
                         alt="@Model.Title"
                         class="img-fluid rounded-start"
                         style="max-height:600px; object-fit:cover;" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center h-100 p-3 text-muted">
                        Sin imagen
                    </div>
                }
            </div>

            <div class="col-md-8">
                <div class="card-body">
                    <h2 class="card-title mb-4">@Model.Title</h2>

                    <p><strong>Título original:</strong> @(string.IsNullOrWhiteSpace(Model.OriginalTitle) ? "No disponible" : Model.OriginalTitle)</p>
                    <p><strong>Fecha:</strong> @(string.IsNullOrWhiteSpace(Model.ReleaseDate) ? "No disponible" : Model.ReleaseDate)</p>
                    <p><strong>Idioma:</strong> @(string.IsNullOrWhiteSpace(Model.OriginalLanguage) ? "No disponible" : Model.OriginalLanguage)</p>
                    <p><strong>Calificación:</strong> @Model.VoteAverage</p>

                    <p>
                        <strong>Géneros:</strong>
                        @if (Model.Genres != null && Model.Genres.Any())
                        {
                            @string.Join(", ", Model.Genres.Select(g => g.Name))
                        }
                        else
                        {
                            <span>No disponible</span>
                        }
                    </p>

                    <hr />

                    <p>@(string.IsNullOrWhiteSpace(Model.Overview) ? "Sin descripción disponible." : Model.Overview)</p>

                    <div class="mt-3">
                        <button id="btnAddLibrary" class="btn btn-success" onclick="addToLibrary(@Model.Id)">
                            ➕ Agregar a biblioteca
                        </button>
                        <div id="libraryStatusMessage" class="form-text mt-2 text-muted"></div>
                    </div>

                 

                    <div class="mt-2">
                        <button class="btn btn-warning" onclick="toggleFavorite()">
                            ⭐ Favorito
                        </button>
                    </div>

                    <div class="mt-2">
                        <select id="statusSelect" class="form-select" onchange="changeStatus(this.value)">
                            <option value="1">Pendiente</option>
                            <option value="2">Viendo</option>
                            <option value="3">Vista</option>
                            <option value="4">Abandonada</option>
                        </select>
                    </div>

                    <div class="mt-3">
                        <input type="number" id="rating" class="form-control mb-2" placeholder="Rating (1-5)" />
                        <input type="text" id="comment" class="form-control mb-2" placeholder="Comentario" />

                        <button class="btn btn-primary" onclick="addReview()">
                            💬 Guardar comentario
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <h3 class="mb-3">Recomendaciones</h3>

    @if (Model.Recommendations != null && Model.Recommendations.Any())
    {
        <div class="row">
            @foreach (var movie in Model.Recommendations)
            {
                <div class="col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        @if (!string.IsNullOrWhiteSpace(movie.PosterPath))
                        {
                            <img src="@($"https://image.tmdb.org/t/p/w300{movie.PosterPath}")"
                                 alt="@movie.Title"
                                 class="card-img-top"
                                 style="height:350px; object-fit:cover;" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center bg-light text-muted" style="height:350px;">
                                Sin imagen
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@movie.Title</h5>
                            <p class="card-text">@(string.IsNullOrWhiteSpace(movie.ReleaseDate) ? "No disponible" : movie.ReleaseDate)</p>

                            <div class="mt-auto">
                                <a asp-action="Details" asp-route-id="@movie.Id" class="btn btn-outline-primary w-100">
                                    Ver detalle
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-secondary">
            No hay recomendaciones disponibles.
        </div>
    }
</div>

<script>
    const api = "https://localhost:7174";
    const tmdbId = @Model.Id;

    let currentLibraryId = null;

    function updateLibraryButtonState(isInLibrary) {
        const addButton = document.getElementById("btnAddLibrary");
        const statusMessage = document.getElementById("libraryStatusMessage");

        if (!addButton || !statusMessage) return;

        if (isInLibrary) {
            addButton.disabled = true;
            addButton.classList.remove("btn-success");
            addButton.classList.add("btn-secondary");
            addButton.innerText = "✔ Ya está en tu biblioteca";
            statusMessage.innerText = "Esta película ya fue agregada y puedes editar su estado, favorito o comentario.";
        } else {
            addButton.disabled = false;
            addButton.classList.remove("btn-secondary");
            addButton.classList.add("btn-success");
            addButton.innerText = "➕ Agregar a biblioteca";
            statusMessage.innerText = "";
        }
    }

    async function loadLibraryItem() {
        try {
            const res = await fetch(`${api}/api/Library/tmdb/${tmdbId}`);

            if (res.status === 404) {
                updateLibraryButtonState(false);
                return;
            }

            if (!res.ok) {
                throw new Error("No se pudo consultar la biblioteca");
            }

            const item = await res.json();
            currentLibraryId = item.id;

            updateLibraryButtonState(true);

            const statusSelect = document.getElementById("statusSelect");
            const ratingInput = document.getElementById("rating");
            const commentInput = document.getElementById("comment");

            if (statusSelect) {
                const statusMap = {
                    "Pending": 1,
                    "Watching": 2,
                    "Watched": 3,
                    "Dropped": 4,
                    "Pendiente": 1,
                    "Viendo": 2,
                    "Vista": 3,
                    "Abandonada": 4
                };

                if (typeof item.status === "number") {
                    statusSelect.value = item.status;
                } else if (statusMap[item.status] !== undefined) {
                    statusSelect.value = statusMap[item.status];
                }
            }

            if (ratingInput) {
                ratingInput.value = item.rating ?? "";
            }

            if (commentInput) {
                commentInput.value = item.comment ?? "";
            }
        } catch (e) {
            console.error(e);
            updateLibraryButtonState(false);
        }
    }

    async function addToLibrary(tmdbId) {
        try {
            const res = await fetch(`${api}/api/Library`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    tmdbId: tmdbId,
                    status: 1
                })
            });

            if (!res.ok) {
                throw new Error("No se pudo agregar la película a la biblioteca");
            }

            const data = await res.json();
            currentLibraryId = data.id;

            updateLibraryButtonState(true);
            alert("Agregado a biblioteca");
            await loadLibraryItem();
        } catch (e) {
            console.error(e);
            alert("Error al agregar");
        }
    }

    async function toggleFavorite() {
        if (!currentLibraryId) {
            return alert("Primero agrega la película a biblioteca");
        }

        try {
            const res = await fetch(`${api}/api/Library/${currentLibraryId}/favorite`, {
                method: "PUT"
            });

            if (!res.ok) {
                throw new Error("No se pudo actualizar favorito");
            }

            alert("Favorito actualizado");
        } catch (e) {
            console.error(e);
            alert("Error al actualizar favorito");
        }
    }

    async function changeStatus(status) {
        if (!currentLibraryId) {
            return alert("Primero agrega la película a biblioteca");
        }

        try {
            const res = await fetch(`${api}/api/Library/${currentLibraryId}/status`, {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    status: parseInt(status)
                })
            });

            if (!res.ok) {
                throw new Error("No se pudo actualizar el estado");
            }
        } catch (e) {
            console.error(e);
            alert("Error al actualizar estado");
        }
    }

    async function addReview() {
        if (!currentLibraryId) {
            return alert("Primero agrega la película a biblioteca");
        }

        const ratingValue = document.getElementById("rating").value;
        const comment = document.getElementById("comment").value;

        const body = {
            rating: ratingValue ? parseInt(ratingValue) : null,
            comment: comment
        };

        try {
            const res = await fetch(`${api}/api/Library/${currentLibraryId}/review`, {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(body)
            });

            if (!res.ok) {
                throw new Error("No se pudo guardar el comentario");
            }

            alert("Comentario guardado");
        } catch (e) {
            console.error(e);
            alert("Error al guardar comentario");
        }
    }

    loadLibraryItem();
</script>