@model Proyecto_PlataformaPeliculas.Models.MovieDetailViewModel

@{
    ViewData["Title"] = "Recomendaciones";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary">← Volver al explorador</a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-2 text-center">
                    @if (!string.IsNullOrWhiteSpace(Model.PosterPath))
                    {
                        <img src="@($"https://image.tmdb.org/t/p/w300{Model.PosterPath}")"
                             alt="@Model.Title"
                             class="img-fluid rounded"
                             style="max-height:220px; object-fit:cover;" />
                    }
                    else
                    {
                        <div class="bg-light text-muted d-flex align-items-center justify-content-center rounded"
                             style="height:220px;">
                            Sin imagen
                        </div>
                    }
                </div>

                <div class="col-md-10">
                    <h1 class="mb-2">Recomendaciones basadas en @Model.Title</h1>
                    <p class="text-muted mb-2">
                        Fecha: @(string.IsNullOrWhiteSpace(Model.ReleaseDate) ? "No disponible" : Model.ReleaseDate)
                        |
                        Idioma: @(string.IsNullOrWhiteSpace(Model.OriginalLanguage) ? "No disponible" : Model.OriginalLanguage)
                        |
                        Calificación: @Model.VoteAverage
                    </p>
                    <p class="mb-0">
                        @(string.IsNullOrWhiteSpace(Model.Overview)
                                                ? "Sin descripción disponible."
                                                : Model.Overview)
                    </p>
                </div>
            </div>
        </div>
    </div>

    <h3 class="mb-3">Películas recomendadas</h3>

    @if (Model.Recommendations != null && Model.Recommendations.Any())
    {
        <div class="row">
            @foreach (var movie in Model.Recommendations)
            {
                <div class="col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        @if (!string.IsNullOrWhiteSpace(movie.PosterPath))
                        {
                            <img src="@($"https://image.tmdb.org/t/p/w300{movie.PosterPath}")"
                                 alt="@movie.Title"
                                 class="card-img-top"
                                 style="height:350px; object-fit:cover;" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center bg-light text-muted"
                                 style="height:350px;">
                                Sin imagen
                            </div>
                        }

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@movie.Title</h5>

                        <p class="card-text">
                            @(string.IsNullOrWhiteSpace(movie.ReleaseDate)
                                                    ? "No disponible"
                                                    : movie.ReleaseDate)
                    </p>

                            <div class="mt-auto d-grid gap-2">
                                <a asp-action="Details"
                                   asp-route-id="@movie.Id"
                                   class="btn btn-outline-primary">
                                    Ver detalle
                                </a>

                                <a asp-action="Recommendations"
                                   asp-route-id="@movie.Id"
                                   class="btn btn-outline-success">
                                    Ver recomendaciones
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                }
        </div>
    }
    else
    {
        <div class="alert alert-secondary">
            No hay recomendaciones disponibles.
        </div>
    }
</div>